# cc-statusline-widgets theme config
# 複製到 ~/.claude/cc-widgets-theme.conf 後修改（plain bash，被 wrapper source）

WT_THEME="claude-coral"   # claude-coral | catppuccin-mocha | nord | gruvbox-dark | tokyo-night | mono
WT_STYLE="pill"           # pill: powerline 藥丸 | lean: 無背景純色文字
WT_LAYOUT="fixed"         # fixed: 固定三行（語意分組）| auto: 單流貪婪換行
WT_MAX_LINES=3            # auto 模式最多折成幾行
WT_BAR_WIDTH=10           # ctx 量條寬度

# 進階：覆寫個別 widget 背景色（256 色編號或 "R,G,B"）
# WT_BG_MODEL=173
# WT_BG_CACHE=237
# WT_BG_SKILL=96
# WT_BG_GIT_OK=65
# WT_BG_GIT_DIRTY=130
# WT_BG_COST="212,125,145"
# WT_BG_USAGE=236
# WT_BG_VENDOR="70,80,110"
# WT_BG_CTX=238
# WT_BG_SYS=240
# WT_BG_SYS2=60
